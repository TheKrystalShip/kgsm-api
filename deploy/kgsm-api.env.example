# kgsm-api.env — host-specific config + secrets for the kgsm-api systemd unit.
#
# Copy to /etc/kgsm-api/kgsm-api.env (root:<kgsm-user> 0640) and fill in. Every value here
# OVERRIDES the unit's Environment= defaults (the unit reads this file last). Each key is the
# same name as in appsettings.json; see kgsm-api/CLAUDE.md for the full schema.

# ── REQUIRED ────────────────────────────────────────────────────────────────
# A stable, random signing key for the auth JWTs + refresh tokens. Generate ONCE:
#     openssl rand -base64 48
# It must NOT change between restarts: an unset/rotated key means a new (often per-boot
# random) key, which invalidates every issued session + refresh token — i.e. everyone is
# logged out. Refresh tokens now last 30 days, so a STABLE key is precisely what makes
# "open the panel next week, still signed in" work.
KGSM_API_AUTH_SIGNING_KEY=

# ── Discord OAuth (Model A) — the same app/guild/bot the host's Discord bot uses ──────────
# Option A: fill these in and keep ASPNETCORE_ENVIRONMENT=Production (the unit default).
KGSM_API_AUTH_DISCORD_CLIENT_ID=
KGSM_API_AUTH_DISCORD_CLIENT_SECRET=
KGSM_API_AUTH_DISCORD_BOT_TOKEN=
KGSM_API_AUTH_DISCORD_GUILD_ID=
# This host's own callback (must EXACTLY match a redirect URI registered in the Discord app).
KGSM_API_AUTH_DISCORD_REDIRECT_URI=https://kgsm.thekrystalship.com/auth/discord/callback
# Discord role id -> tier (who is admin / operator / viewer):
KGSM_API_AUTH_ROLE_ADMIN=
KGSM_API_AUTH_ROLE_OPERATOR=
KGSM_API_AUTH_ROLE_VIEWER=
#
# Option B (dev): instead of the Discord/* keys above, ship appsettings.Development.json next
# to the binary in /opt/kgsm-api and uncomment the next line to load creds from it:
# ASPNETCORE_ENVIRONMENT=Development

# ── SPA wiring ────────────────────────────────────────────────────────────────
# Kestrel SERVES the SPA at / on this same origin (the deploy bundles it into wwwroot), so the
# SPA and API share ONE domain — there is no cross-origin request in prod.
# Post-login redirect target = where the SPA is served = this same origin. (dev: http://localhost:5173)
KGSM_API_AUTH_FRONTEND_URL=https://kgsm.thekrystalship.com
# CORS allowlist. NOT NEEDED for the same-origin SPA above (a same-origin request never triggers
# CORS) — leave BLANK in prod. Only set it if a DIFFERENT origin must reach this API (e.g. a SPA
# served elsewhere, or another host's SPA in the multi-host registry). (dev: blank = any origin.)
KGSM_API_CORS_ORIGINS=

# ── HTTPS / TLS — Kestrel terminates TLS directly (NO reverse proxy) ──────────
# This host serves BOTH the SPA (at /) and the API (under /api/v1) at https://kgsm.thekrystalship.com,
# with Kestrel terminating TLS itself.
# Cert = Let's Encrypt via certbot (the certbot.timer renews it — not a resident service):
#   sudo certbot certonly --standalone -d kgsm.thekrystalship.com   # port 80 must be free
# certbot writes the cert root-readable only, but kgsm-api runs as a NON-root user — so install
# the committed deploy/certbot-deploy-hook.sh, which copies the cert+key to a service-readable
# path (/etc/kgsm-api/tls, 0640) and restarts the unit on every issuance/renewal:
#   sudo install -m 0755 deploy/certbot-deploy-hook.sh \
#        /etc/letsencrypt/renewal-hooks/deploy/kgsm-api.sh
# Then point Kestrel at the service-readable copies (Kestrel__* are STANDARD ASP.NET keys).
# Bind PUBLIC https on :443 (Kestrel terminates TLS) + a PUBLIC plain-http :80 whose ONLY job is to
# 308-redirect bare http -> https (Startup; "we don't allow bare http") + a LOOPBACK plain-http
# ops/health port (:8097, EXEMPT from that redirect — the deploy /health probe + local ops use it).
# :80 and :443 are privileged ports, so the unit grants CAP_NET_BIND_SERVICE to the non-root service.
KGSM_API_URLS=http://0.0.0.0:80;https://0.0.0.0:443;http://127.0.0.1:8097
Kestrel__Certificates__Default__Path=/etc/kgsm-api/tls/fullchain.pem
Kestrel__Certificates__Default__KeyPath=/etc/kgsm-api/tls/privkey.pem
# Stable base for the absolute URLs the API emits (e.g. library cover-art links). With real TLS
# the request scheme is already https, but pinning a single fixed host is tidy:
KGSM_API_PUBLIC_BASE_URL=https://kgsm.thekrystalship.com

# ── Optional overrides (defaults are in the unit) ─────────────────────────────
# KGSM_API_MONITOR_SOCKET=/run/kgsm-monitor/metrics.sock
# KGSM_API_KGSM_PATH=/home/heisen/tks/kgsm/kgsm.sh

# ── GC / memory tuning ────────────────────────────────────────────────────────
# Workstation GC + ConserveMemory + RetainVM is now BAKED INTO THE BUILD (Api.csproj +
# src/Api/runtimeconfig.template.json), so you do NOT need anything here. These env vars are
# only an optional override if you want to A/B test the GC mode on a host without rebuilding:
# DOTNET_gcServer=0
# DOTNET_GCConserveMemory=9
# DOTNET_GCRetainVM=0
