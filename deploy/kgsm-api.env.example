# kgsm-api.env — host-specific config + secrets for the kgsm-api systemd unit.
#
# Copy to /etc/kgsm-api/kgsm-api.env (root:<kgsm-user> 0640) and fill in. Every value here
# OVERRIDES the unit's Environment= defaults (the unit reads this file last). Each key is the
# same name as in appsettings.json; see kgsm-api/CLAUDE.md for the full schema.

# ── REQUIRED ────────────────────────────────────────────────────────────────
# A stable, random signing key for the auth JWTs + refresh tokens. Generate ONCE:
#     openssl rand -base64 48
# It must NOT change between restarts: an unset/rotated key means a new (often per-boot
# random) key, which invalidates every issued session + refresh token — i.e. everyone is
# logged out. Refresh tokens now last 30 days, so a STABLE key is precisely what makes
# "open the panel next week, still signed in" work.
KGSM_API_AUTH_SIGNING_KEY=

# ── Discord OAuth (Model A) — the same app/guild/bot the host's Discord bot uses ──────────
# Option A: fill these in and keep ASPNETCORE_ENVIRONMENT=Production (the unit default).
KGSM_API_AUTH_DISCORD_CLIENT_ID=
KGSM_API_AUTH_DISCORD_CLIENT_SECRET=
KGSM_API_AUTH_DISCORD_BOT_TOKEN=
KGSM_API_AUTH_DISCORD_GUILD_ID=
KGSM_API_AUTH_DISCORD_REDIRECT_URI=http://YOUR_HOST:8080/auth/discord/callback
# Discord role id -> tier (who is admin / operator / viewer):
KGSM_API_AUTH_ROLE_ADMIN=
KGSM_API_AUTH_ROLE_OPERATOR=
KGSM_API_AUTH_ROLE_VIEWER=
#
# Option B (dev): instead of the Discord/* keys above, ship appsettings.Development.json next
# to the binary in /opt/kgsm-api and uncomment the next line to load creds from it:
# ASPNETCORE_ENVIRONMENT=Development

# ── SPA wiring ────────────────────────────────────────────────────────────────
# Post-login redirect target (where the SPA is served):
KGSM_API_AUTH_FRONTEND_URL=http://localhost:5173
# CORS allowlist for the SPA origin(s), comma-separated. Blank = any origin (dev only).
KGSM_API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Optional overrides (defaults are in the unit) ─────────────────────────────
# KGSM_API_URLS=http://0.0.0.0:8097
# KGSM_API_MONITOR_SOCKET=/run/kgsm-monitor/metrics.sock
# KGSM_API_KGSM_PATH=/home/heisen/tks/kgsm/kgsm.sh
