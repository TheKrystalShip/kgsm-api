{
  // === KGSM Control Panel API — per-host configuration ===
  // This file is the documented schema and default values. Every KGSM_API_* key below is
  // also overridable by an environment variable of the SAME name (the env value wins over
  // this file) — that is how the systemd unit configures a deployed host. Edit a value here
  // for a local default, or set the matching KGSM_API_* env var on the host.

  // HTTP bind address(es); semicolon-separated for multiple (e.g. "http://0.0.0.0:8080").
  // PRODUCTION (Kestrel terminates TLS directly — no reverse proxy): set this to
  // "https://0.0.0.0:443" and supply a cert via the STANDARD ASP.NET Kestrel keys (auto-bound
  // from the "Kestrel" section, NOT KGSM_API_* keys) — e.g. the env vars
  // Kestrel__Certificates__Default__Path / __KeyPath pointing at a PEM cert+key (Let's Encrypt
  // via certbot). Binding 443 as the non-root service needs CAP_NET_BIND_SERVICE (in the unit).
  // See deploy/kgsm-api.env.example. Left as plain-http loopback here so dev/fallback needs no cert.
  "KGSM_API_URLS": "http://127.0.0.1:8080",

  // Stable identity of THIS host (architecture §4·a). Blank => the OS machine name is used.
  "KGSM_API_HOST_ID": "",
  // Human-friendly label shown in the UI. Blank => falls back to the host id. This is the DEFAULT; an admin
  // PATCH /hosts/{id} override (stored in the host_settings table) wins at runtime.
  "KGSM_API_HOST_LABEL": "",
  // Deployment region for the host identity card — an ARBITRARY free string (e.g. "eu-west", "us-east",
  // "homelab"), NOT a restricted set. Surfaced on GET /hosts (identity.region) and the open GET /api/v1
  // handshake. Blank => unset (honest unknown, never guessed). The DEFAULT; an admin PATCH /hosts/{id}
  // override wins at runtime.
  "KGSM_API_REGION": "",

  // --- The kgsm engine (base, not a leaf — the single C#<->engine chokepoint kgsm-lib shells).
  //     The api co-locates with a kgsm, so this is provisioned by default at the packaged path.
  //     Blank is a misconfiguration (NOT a capability toggle): /servers is empty + a loud log. ---
  // Path to the host's kgsm.sh entrypoint (AUR installs the /usr/bin/kgsm symlink).
  "KGSM_API_KGSM_PATH": "/usr/bin/kgsm",
  // kgsm event socket — the M5 audit consumer BINDS + listens here (kgsm connects outbound and pushes
  // events; only events fired while the api is listening are audited — no backfill). MUST be a DEDICATED
  // path: the listener deletes any file at this path before binding, so never point it at a socket
  // another consumer owns. Default lives in the API's own systemd RuntimeDirectory (/run/kgsm-api/,
  // created+owned by the service user) — matching deploy/kgsm-api.service. This path must be listed in
  // kgsm's [events] config_event_socket_filenames (the multi-listener list) for kgsm to deliver here.
  "KGSM_API_KGSM_SOCKET": "/run/kgsm-api/kgsm-events.sock",

  // --- Leaf endpoints. A BLANK value reports that capability as "absent" (declared off),
  //     a configured-but-unreachable endpoint reports "down". (system-architecture §4·b) ---
  // kgsm-monitor metrics unix socket (the monitor's listen default — keep this == kgsm-monitor's
  // KGSM_MONITOR_SOCKET so the connect/listen defaults agree across projects).
  "KGSM_API_MONITOR_SOCKET": "/run/kgsm-monitor/metrics.sock",
  // kgsm-watchdog control unix socket.
  "KGSM_API_WATCHDOG_SOCKET": "/run/kgsm-watchdog/control.sock",
  // Assistant base URL (HTTP/SSE turn relay lands at M7). Blank => assistant absent.
  "KGSM_API_ASSISTANT_URL": "",
  // Shared secret for the M7 assistant turn relay (X-Relay-Secret); must match the assistant's
  // Assistant:Relay:Secret so it trusts the API's forwarded end-user identity. Blank => none sent.
  "KGSM_API_ASSISTANT_RELAY_SECRET": "",
  // kgsm-firewall control unix socket (M6·b — the ports surface). OPT-IN: blank => the firewall
  // authority is "absent" (per-server network.firewall:"absent", host network null). Set to
  // /run/kgsm-firewall/firewall.sock on a host that runs kgsm-firewall. NOT health-polled (the
  // daemon is socket-activated + idle-exits); probed on-demand per detail view + the open_ports verify.
  "KGSM_API_FIREWALL_SOCKET": "",
  // kgsm-scheduler status unix socket (Settings Phase 3 — scheduled restart). The scheduler exposes an
  // NDJSON status snapshot (nextFireUtc + last-run) at this path. OPT-IN: blank => the scheduler leaf is
  // "absent" (nextFireUtc null on GET /servers/{id}/settings, scheduler capability absent). Set to
  // /run/kgsm-scheduler/status.sock on a host that runs kgsm-scheduler. NOT installed/deployed here.
  "KGSM_API_SCHEDULER_SOCKET": "",

  // --- Library cover-art / metadata (RAWG.io) — the installable-game catalog's cover/hero/description/
  //     genres/tags. OPT-IN: blank key => no hydration (cover/hero null, genres/tags []; SPA gradient
  //     fallback). The slug lives on the kgsm blueprint (metadata.rawg_slug); the API fetches + self-hosts. ---
  // RAWG.io API key. Blank => the hydration worker no-ops. A SECRET (the RAWG client strips its HttpClient
  // loggers so the ?key=... never logs). Set it on a host to enable cover/metadata hydration.
  "KGSM_API_RAWG_API_KEY": "",
  // Directory the self-hosted cover/hero .jpgs are written to + served from. Blank => a covers/ dir beside
  // the SQLite DB (KGSM_API_DB's directory — /var/lib/kgsm-api/covers on a deployed host).
  "KGSM_API_RAWG_CACHE_DIR": "",
  // Optional public base URL (e.g. https://panel.example.com) the absolute cover/hero URLs are built from
  // for a reverse-proxy deployment. Blank => derived from the incoming request ({scheme}://{host}), which
  // resolves per-host for the multi-host SPA registry. Any trailing slash is trimmed.
  "KGSM_API_PUBLIC_BASE_URL": "",
  // Cover-art AUTHORITY: the Steam library capsule (the 2:3 portrait Steam shows in its library view),
  // {base}/{client_steam_app_id}/library_600x900.jpg. KEYLESS + DECOUPLED from RAWG — Steam covers hydrate
  // even with no RAWG key; RAWG's background_image is only the fallback (a game not on Steam / no capsule).
  // Blank => the default Steam store-asset CDN below. Any trailing slash is trimmed.
  "KGSM_API_STEAM_CDN_BASE": "https://shared.fastly.steamstatic.com/store_item_assets/steam/apps",
  // Off switch for the keyless Steam cover source ("1"/"true"/"yes"/"on"). Default off (Steam covers ON);
  // set it to fall back to RAWG-only (and the offline smoke sets it so cover stays null with no RAWG key).
  "KGSM_API_STEAM_COVERS_DISABLED": "",
  // Periodic refresh of the cover/metadata cache (in-process, off the request path). The worker wakes daily at
  // the local hour below and re-fetches any game whose cached data is older than this many days. 7 = weekly
  // (cover/metadata is near-static, so weekly is plenty); 0 disables the periodic wake (boot sweep + the admin
  // POST /library/refresh only). A re-fetch only rewrites an image when its bytes actually changed.
  "KGSM_API_LIBRARY_REFRESH_INTERVAL_DAYS": "7",
  // Local hour-of-day (0–23) the periodic refresh wakes to check — a quiet window. Default 06:00.
  "KGSM_API_LIBRARY_REFRESH_HOUR": "6",
  // Blueprint in-memory cache TTL (background refresh interval). Blueprints change infrequently
  // (install/uninstall), so a short staleness window is acceptable. Floor 10s.
  "KGSM_API_BLUEPRINT_CACHE_TTL_SECONDS": "60",
  // Instance in-memory cache TTL (background refresh interval). Instances change infrequently and kgsm
  // events update runtime state between refreshes. Floor 10s.
  "KGSM_API_INSTANCE_CACHE_TTL_SECONDS": "60",

  // --- File browser (Tier 3 #12 — GET/PUT /servers/{id}/files). Operator-gated; scoped to each
  //     instance's working directory. ---
  // Max directory entries one list returns before truncating (with a truncated:true signal). The cap is a
  // FRONTEND-render bound (one DOM node per entry), not an API-cost one. Default 200.
  "KGSM_API_FILES_MAX_ENTRIES": "200",
  // Max file size (bytes) the editor will open/save; larger => file_too_large (shown honestly, never
  // rendered as garbage). Default 2 MiB.
  "KGSM_API_FILES_MAX_EDIT_BYTES": "2097152",

  // SQLite file for the API's own operational metadata (audit M5; auth M4 is stateless — no rows).
  "KGSM_API_DB": "kgsm-api.db",

  // --- Leaf runtime config (the Services panel config broker — admin-gated). The API never edits a leaf's
  //     own files; it renders a separate OVERRIDE layer a systemd drop-in feeds the leaf, then restarts with
  //     a health-canary + auto-rollback. ---
  // Directory the per-leaf override files (<leaf>.env) render to. The API's OWN state dir, so it writes them
  // unprivileged (0600); a systemd drop-in (installed once, out-of-band) feeds them via EnvironmentFile=-.
  "KGSM_API_LEAF_OVERRIDES_DIR": "/var/lib/kgsm-api/leaf-overrides",
  // How long (ms) to watch a leaf's health after a config restart before declaring the change good; not
  // healthy in time => the override is restored + the leaf restarted again (auto-rollback). Floor 2000.
  "KGSM_API_LEAF_APPLY_CANARY_MS": "15000",

  // --- Realtime pump cadences (M2) — the background WS poll intervals (both gated on subscribers). ---
  // How often the `servers` topic re-fetches the instance roster + run-state from kgsm (ms). Each tick
  // spawns kgsm.sh and the roster changes rarely (the SPA also has a manual refresh), so this is relaxed.
  // Floor 1000. Operator start/stop/install already push an immediate verify patch off the command path —
  // this poll only catches out-of-band changes. Blueprints have NO separate poll (GET /library is live).
  "KGSM_API_DOMAIN_POLL_MS": "5000",
  // How often the `*/metrics` topics scrape the monitor for the live resource tick (ms). This is the live
  // performance feed (≈ the monitor's self-tick), NOT the instance poll — keep it ~1s or the charts get
  // choppy. Floor 250. (Distinct from KGSM_API_METRICS_PERSIST_MS, the durable-history sampler cadence.)
  "KGSM_API_METRICS_POLL_MS": "1000",

  // --- Metrics history (M9) — durable tiered metrics store (a SEPARATE metrics.db, D4). ---
  // Master switch: "1"/"true" DISABLES history (the sampler is inert, read endpoints empty).
  "KGSM_API_METRICS_HISTORY_DISABLED": "",
  // Dedicated SQLite file (not the audit DB). Blank => metrics.db beside KGSM_API_DB.
  "KGSM_API_METRICS_HISTORY_DB": "",
  // Tier-1 persist cadence (ms). Floor 5000. Decoupled from the 1 Hz live stream.
  "KGSM_API_METRICS_PERSIST_MS": "15000",
  // Tier-1 raw sample retention (hours).
  "KGSM_API_METRICS_RAW_RETENTION_HOURS": "24",
  // Tier-2 rollup bucket width (minutes).
  "KGSM_API_METRICS_ROLLUP_STEP_MIN": "5",
  // Tier-2 rollup retention (days).
  "KGSM_API_METRICS_ROLLUP_RETENTION_DAYS": "30",
  // How often the maintenance job runs rollup + prune (ms).
  "KGSM_API_METRICS_MAINT_MS": "60000",

  // --- Metric-threshold alerts (the alerts `metrics`/`host-monitor` source — increment 1 of 2; see
  //     metrics-threshold-alerts-plan.md). Policy storage is appsettings/env ONLY this increment
  //     (DB-backed/panel-editable policy is increment 2). A present, non-empty MetricsThresholds:Rules
  //     section below WINS WHOLESALE over the baked-in default (no partial merge) — tuning a threshold or
  //     enabling a per-server rule means editing this file/env + restarting the API. Host rules ship ON
  //     (%-based, universal); per-server rules ship OFF (absolute thresholds are game-specific — operator
  //     opt-in). A rule's value is honest-unknown (held, never fired) when its source field is null (e.g.
  //     no swap configured, no cpu-info, no hwmon sensors). ---
  // Kill-switch for the whole metric-threshold pass, independent of each rule's own "enabled" flag below.
  "KGSM_API_METRICS_THRESHOLDS_DISABLED": "",
  "MetricsThresholds": {
    "Rules": [
      { "key": "host-disk", "metric": "HostDiskUsedPct", "warn": 90,   "danger": 95,   "fireForSec": 60,  "clearForSec": 300, "clearMargin": 3,   "enabled": true  },
      { "key": "host-mem",  "metric": "HostMemUsedPct",  "warn": 90,   "danger": 97,   "fireForSec": 120, "clearForSec": 120, "clearMargin": 5,   "enabled": true  },
      { "key": "host-swap", "metric": "HostSwapUsedPct", "warn": 50,   "danger": 90,   "fireForSec": 120, "clearForSec": 120, "clearMargin": 10,  "enabled": true  },
      { "key": "host-load", "metric": "HostLoadPerCore", "warn": 1.5,  "danger": 4.0,  "fireForSec": 120, "clearForSec": 120, "clearMargin": 0.3, "enabled": true  },
      { "key": "host-temp", "metric": "HostTempC",       "warn": 85,   "danger": 95,   "fireForSec": 30,  "clearForSec": 60,  "clearMargin": 5,   "enabled": true  },
      { "key": "srv-pids",  "metric": "ServerPids",      "warn": 1000, "danger": null, "fireForSec": 120, "clearForSec": 120, "clearMargin": 50,  "enabled": false },
      { "key": "srv-mem",   "metric": "ServerMemBytes",  "warn": 0,    "danger": null, "fireForSec": 120, "clearForSec": 120, "clearMargin": 0,   "enabled": false },
      { "key": "srv-cpu",   "metric": "ServerCpuPctCore","warn": 0,    "danger": null, "fireForSec": 120, "clearForSec": 120, "clearMargin": 0,   "enabled": false }
    ]
  },

  // CORS allowlist: comma-separated origins. Blank => any-origin (dev only). Bearers ride the
  // Authorization header (not cookies), so any-origin stays safe for reads; set real origins by deploy.
  "KGSM_API_CORS_ORIGINS": "",

  // --- Auth (M4·a) — Discord per-host, Model A (architecture.html §3·f). Identity is a global
  //     Discord SSO anchor; authorization is a short-lived host-scoped JWT this host mints after
  //     verifying identity once and resolving the role via the host's bot. Stateless: no user rows.
  //     AUTH IS ON BY DEFAULT. The Discord app/guild/bot-token/role ids are SHARED EXTERNAL CONFIG
  //     (the same values the host's Discord bot uses) — configuration, not a dependency on the bot. ---
  // Dev escape hatch: "1"/"true" authenticates every request as a synthetic admin (the pre-M4 open
  // window, now explicit + loudly logged). Leave blank in any real/exposed deployment.
  "KGSM_API_AUTH_DISABLED": "",
  // HMAC signing key for the session JWTs. Blank + auth on => an EPHEMERAL key is generated per
  // process (tokens die on restart; logged loudly). Set a long, stable secret on a real host.
  "KGSM_API_AUTH_SIGNING_KEY": "",
  // Discord OAuth application (reuse the host bot's app). The login flow (M4·b) needs all five;
  // until they are set the /auth/discord/* endpoints return 503, but JWT validation + tier gating
  // are enforced regardless (everything 401s without a bearer).
  "KGSM_API_AUTH_DISCORD_CLIENT_ID": "",
  "KGSM_API_AUTH_DISCORD_CLIENT_SECRET": "",
  // This host's OAuth redirect URI — its own /auth/discord/callback (must match the app's registry).
  "KGSM_API_AUTH_DISCORD_REDIRECT_URI": "",
  // Bot token used to read guild member roles (GET /guilds/{guild}/members/{user}) — the ONLY path
  // to roles (the identify+guilds user scopes don't carry them). Same token the host's bot uses.
  "KGSM_API_AUTH_DISCORD_BOT_TOKEN": "",
  // The guild whose roles authorize this host.
  "KGSM_API_AUTH_DISCORD_GUILD_ID": "",
  // The SPA origin the OAuth callback hands the session back to. When set, the callback 302s the
  // browser here with the result in the URL fragment (#access=...&refresh=... | #error=...) instead
  // of returning JSON. Single fixed target (no open-redirect). Blank => callback returns JSON.
  "KGSM_API_AUTH_FRONTEND_URL": "",
  // Role id -> tier mapping (comma-separated role ids per tier). Effective tier = the highest a
  // member's roles grant; no match => 'none' => terminal 403. (admin > operator > viewer > none.)
  // The bot's existing Ops role (ActionRoleId) maps naturally to operator.
  "KGSM_API_AUTH_ROLE_ADMIN": "",
  "KGSM_API_AUTH_ROLE_OPERATOR": "",
  "KGSM_API_AUTH_ROLE_VIEWER": "",

  // --- Standard ASP.NET Core keys ---
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
