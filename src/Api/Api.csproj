<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <InvariantGlobalization>true</InvariantGlobalization>
    <RootNamespace>TheKrystalShip.Api</RootNamespace>
    <AssemblyName>kgsm-api</AssemblyName>

    <!-- Standard JIT (no Native AOT) — deliberate trade for long-term maintainability:
         it unlocks the conventional MVC controllers + EF Core stack, which AOT forbids.
         See docs/m0-aot-spike-findings.md and PLAN.md §8 for the decision record.
         Deploy is self-contained (publish with -r linux-x64 and the self-contained flag),
         so the per-host "drop-in, no runtime install" story still holds — just a larger
         artifact than the AOT binary would have been. ReadyToRun enabled at publish time. -->
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.5" />

    <!-- M4·a auth — JWT bearer validation for the host-scoped session tokens (stateless JWT,
         no session table; the M4 bearer decision). Brings Microsoft.IdentityModel.* transitively,
         which SessionTokenService uses to mint/validate. Standard under JIT (no AOT concern). -->
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.5" />

    <!-- The single C#<->engine chokepoint: instances, run-state, the watchdog client
         (IWatchdogClient, M1 capability probe), and — from 1.8.0 (M5) — the kgsm event
         stream's Origin field + the lifecycle (actor, origin) provenance params the command
         path stamps so the resulting event carries who/through-what. 1.8.0 also rides 1.7.0's
         watchdog /health switch. Never shell kgsm.sh. -->
    <PackageReference Include="TheKrystalShip.KGSM.Lib" Version="1.8.0" />

    <!-- The shared GET /metrics wire contract (Snapshot graph + source-gen camelCase
         JSON), built in kgsm-monitor. We deserialize the monitor scrape into these exact
         types with the same JSON context, so the contract is solid at build time and
         cannot drift between the monitor (producer) and this api (consumer). -->
    <PackageReference Include="TheKrystalShip.KGSM.Monitor.Contracts" Version="1.0.0" />
  </ItemGroup>

</Project>
