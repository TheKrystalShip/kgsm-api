<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Local folder feed where the TheKrystalShip.* packages are packed during
    development (/home/heisen/local-nuget): KGSM.Lib (the C#<->engine chokepoint,
    1.6.0) and KGSM.Monitor.Contracts (the shared GET /metrics wire contract, built
    and packed from the kgsm-monitor repo). Merged with the global sources
    (nuget.org) so Microsoft.* packages still resolve; mirrors kgsm-monitor's
    nuget.config. Once these are on a hosted feed this local source can be removed.
  -->
  <packageSources>
    <add key="local-thekrystalship" value="/home/heisen/local-nuget" />
  </packageSources>
</configuration>
